generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model usuarios {
  id               Int      @id @default(autoincrement())
  nome             String
  email            String   @unique
  senha            String
  tipo_usuario     String   @default("cliente")
  whatsapp         String?
  url_foto         String?
  data_criacao     DateTime @default(now())
  data_atualizacao DateTime @default(now())
}